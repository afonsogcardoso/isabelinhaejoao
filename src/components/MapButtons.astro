---
import CalendarIcsLink from './CalendarIcsLink.astro';

interface CalendarEvent {
  title: string;
  description: string;
  location: string;
  start: string;
  end: string;
  fileName: string;
}

interface Props {
  googleMapsUrl: string;
  appleMapsUrl: string;
  calendarEvent: CalendarEvent;
}

const { googleMapsUrl, appleMapsUrl, calendarEvent } = Astro.props;
---

<div class="map-buttons">
  <a class="btn btn-secondary" href={googleMapsUrl} target="_blank" rel="noreferrer noopener" aria-label="Abrir no Google Maps">
    Abrir no Google Maps
  </a>
  <a class="btn btn-secondary" href={appleMapsUrl} target="_blank" rel="noreferrer noopener" aria-label="Abrir no Apple Maps">
    Abrir no Apple Maps
  </a>
  <CalendarIcsLink event={calendarEvent} />
</div>
