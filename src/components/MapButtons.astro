---
import CalendarIcsLink from './CalendarIcsLink.astro';

interface CalendarEvent {
  title: string;
  description: string;
  location: string;
  start: string;
  end: string;
  fileName: string;
}

interface Props {
  googleMapsUrl: string;
  calendarEvent: CalendarEvent;
  showCalendar?: boolean;
}

const { googleMapsUrl, calendarEvent, showCalendar = true } = Astro.props;
---

<div class="map-buttons">
  <a class="btn btn-secondary" href={googleMapsUrl} target="_blank" rel="noreferrer noopener" aria-label="Abrir no Google Maps">
    Abrir no Google Maps
  </a>
  {showCalendar ? <CalendarIcsLink event={calendarEvent} /> : null}
</div>
