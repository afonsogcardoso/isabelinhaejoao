---
interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  items: FAQItem[];
}

const { items } = Astro.props;
---

<div class="faq-list" data-faq-list>
  {
    items.map((item, index) => {
      const buttonId = `faq-button-${index}`;
      const panelId = `faq-panel-${index}`;
      return (
        <article class="faq-item">
          <h2>
            <button class="faq-trigger" id={buttonId} type="button" aria-expanded="false" aria-controls={panelId}>
              <strong>{item.question}</strong>
              <span class="faq-icon" aria-hidden="true">+</span>
            </button>
          </h2>
          <div class="faq-panel" id={panelId} role="region" aria-labelledby={buttonId}>
            <div class="faq-panel-inner">
              <p>{item.answer}</p>
            </div>
          </div>
        </article>
      );
    })
  }
</div>

<script>
  const faqRoots = document.querySelectorAll('[data-faq-list]');

  faqRoots.forEach((root) => {
    const buttons = root.querySelectorAll('.faq-trigger');

    const closePanel = (button) => {
      const panelId = button.getAttribute('aria-controls');
      const panel = panelId ? root.querySelector(`#${panelId}`) : null;
      if (!panel) return;
      button.setAttribute('aria-expanded', 'false');
      panel.style.maxHeight = '0px';
    };

    const openPanel = (button) => {
      const panelId = button.getAttribute('aria-controls');
      const panel = panelId ? root.querySelector(`#${panelId}`) : null;
      if (!panel) return;
      button.setAttribute('aria-expanded', 'true');
      panel.style.maxHeight = `${panel.scrollHeight}px`;
    };

    buttons.forEach((button) => {
      button.addEventListener('click', () => {
        const isOpen = button.getAttribute('aria-expanded') === 'true';

        buttons.forEach((other) => {
          if (other !== button) closePanel(other);
        });

        if (isOpen) {
          closePanel(button);
        } else {
          openPanel(button);
        }
      });
    });
  });
</script>
