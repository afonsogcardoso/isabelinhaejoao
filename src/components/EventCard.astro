---
import MapButtons from './MapButtons.astro';

interface CalendarEvent {
  title: string;
  description: string;
  location: string;
  start: string;
  end: string;
  fileName: string;
}

interface EventData {
  title: string;
  date: string;
  time: string;
  location: string;
  address: string;
  image?: {
    src: string;
    alt: string;
  };
  googleMapsUrl: string;
  calendar: CalendarEvent;
}

interface Props {
  event: EventData;
}

const { event } = Astro.props;
const basePath = import.meta.env.BASE_URL;
const resolveAssetUrl = (source: string) => {
  if (!source) return source;
  if (/^(https?:)?\/\//i.test(source) || source.startsWith('data:')) return source;
  return `${basePath}${source.replace(/^\//, '')}`;
};
---

<article class={`event-card ${event.image?.src ? 'event-card-with-image' : ''}`}>
  {
    event.image?.src ? (
      <figure class="event-image-wrap">
        <img
          class="event-image"
          src={resolveAssetUrl(event.image.src)}
          alt={event.image.alt}
          loading="lazy"
          decoding="async"
        />
      </figure>
    ) : null
  }
  <h3>{event.title}</h3>
  <div class="event-meta">
    <p><strong>Hora:</strong> {event.time}</p>
    <p><strong>Local:</strong> {event.location}</p>
    <p><strong>Morada:</strong> {event.address}</p>
  </div>
  <MapButtons googleMapsUrl={event.googleMapsUrl} calendarEvent={event.calendar} />
</article>
