---
import { existsSync, readdirSync } from 'node:fs';
import { extname } from 'node:path';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ImageCarousel from '../components/ImageCarousel.astro';
import siteContent from '../content/site.json';

const { site, about, carouselImages: fallbackCarouselImages } = siteContent;
const basePath = import.meta.env.BASE_URL;
const withBase = (path: string) => `${basePath}${path.replace(/^\//, '')}`;

const carouselDirUrl = new URL('../../public/images/carrossel/', import.meta.url);
const supportedExtensions = new Set(['.avif', '.webp', '.jpg', '.jpeg', '.png', '.gif']);

const makeAltFromFileName = (fileName: string) =>
  fileName
    .replace(/\.[^.]+$/, '')
    .replace(/[_-]+/g, ' ')
    .replace(/\s+/g, ' ')
    .trim()
    .replace(/^./, (char) => char.toUpperCase());

const localCarouselImages = existsSync(carouselDirUrl)
  ? readdirSync(carouselDirUrl, { withFileTypes: true })
      .filter((entry) => entry.isFile() && supportedExtensions.has(extname(entry.name).toLowerCase()))
      .map((entry) => entry.name)
      .sort((a, b) => a.localeCompare(b, 'pt', { numeric: true, sensitivity: 'base' }))
      .map((fileName) => ({
        src: `${basePath}images/carrossel/${encodeURIComponent(fileName)}`,
        alt: makeAltFromFileName(fileName)
      }))
  : [];

const carouselImages = localCarouselImages.length > 0 ? localCarouselImages : fallbackCarouselImages;
---

<BaseLayout title="Início · Isabelinha e João" description={site.description}>
  <Hero names={site.names} date={site.date} location={site.location} />

  <section class="section section-home-carousel" aria-label="Galeria de imagens">
    <div class="container">
      <ImageCarousel images={carouselImages} />
    </div>
  </section>

  <section class="section section-home-about" aria-labelledby="sobre-nos">
    <div class="container">
      <div class="home-about">
        <h2 class="section-title" id="sobre-nos">Sobre nós</h2>
        <p class="about-text">{about}</p>
      </div>
    </div>
  </section>

  <section class="section section-home-nav" aria-label="Explorar páginas">
    <div class="container">
      <nav class="home-nav-grid" aria-label="Navegação rápida">
        <a class="home-nav-card" href={withBase('/evento/')}>
          <strong>O dia 18</strong>
          <span class="home-nav-arrow" aria-hidden="true">→</span>
        </a>
        <a class="home-nav-card" href={withBase('/presente/')}>
          <strong>Presente</strong>
          <span class="home-nav-arrow" aria-hidden="true">→</span>
        </a>
        <a class="home-nav-card" href={withBase('/como-voltar/')}>
          <strong>Como voltar</strong>
          <span class="home-nav-arrow" aria-hidden="true">→</span>
        </a>
      </nav>
    </div>
  </section>

  <section class="section section-home-countdown" aria-label="Contagem decrescente">
    <div class="container">
      <p class="home-countdown" data-home-countdown-target={site.dateIso} aria-live="polite">
        A carregar contagem decrescente...
      </p>
    </div>
  </section>
</BaseLayout>

<script define:vars={{ countdownTarget: site.dateIso }}>
  const countdown = document.querySelector('[data-home-countdown-target]');

  if (countdown) {
    const target = countdown.getAttribute('data-home-countdown-target') || countdownTarget;

    if (target) {
      const targetDate = new Date(target);

      const updateCountdown = () => {
        const now = new Date();
        const diff = targetDate.getTime() - now.getTime();

        if (diff <= 0) {
          countdown.textContent = 'Hoje é o grande dia.';
          return;
        }

        const days = Math.floor(diff / (1000 * 60 * 60 * 24));
        const hours = Math.floor((diff / (1000 * 60 * 60)) % 24);
        const minutes = Math.floor((diff / (1000 * 60)) % 60);

        countdown.textContent = `Faltam ${days} dias, ${hours} horas e ${minutes} minutos.`;
      };

      updateCountdown();
      setInterval(updateCountdown, 60000);
    }
  }
</script>
