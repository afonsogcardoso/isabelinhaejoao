---
import BaseLayout from '../layouts/BaseLayout.astro';
import EventCard from '../components/EventCard.astro';
import siteContent from '../content/site.json';

const { events } = siteContent;
---

<BaseLayout title="O dia 18 · Isabelinha e João" description="Agenda, locais e mapas do dia do casamento.">
  <section class="section section-page-head">
    <div class="container">
      <header class="page-head">
        <h1>O dia 18</h1>
      </header>

      <div class="timeline" aria-label="Timeline do dia 18">
        {
          events.map((event, index) => (
            <div class="timeline-item">
              <span class="timeline-point" aria-hidden="true">{index + 1}</span>
              <EventCard event={event} />
            </div>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
