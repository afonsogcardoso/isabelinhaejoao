---
import { existsSync, readdirSync } from 'node:fs';
import { extname } from 'node:path';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ImageCarousel from '../components/ImageCarousel.astro';
import EventCard from '../components/EventCard.astro';
import GiftCard from '../components/GiftCard.astro';
import siteContent from '../content/site.json';
import giftsContent from '../content/presente.json';

const { site, about, carouselImages: fallbackCarouselImages, events } = siteContent;
const { introducao, introducao2, detalhesPagamento, itens } = giftsContent;
const basePath = import.meta.env.BASE_URL;

const carouselDirUrl = new URL('../../public/images/carrossel/', import.meta.url);
const supportedExtensions = new Set(['.avif', '.webp', '.jpg', '.jpeg', '.png', '.gif']);

const makeAltFromFileName = (fileName: string) =>
  fileName
    .replace(/\.[^.]+$/, '')
    .replace(/[_-]+/g, ' ')
    .replace(/\s+/g, ' ')
    .trim()
    .replace(/^./, (char) => char.toUpperCase());

const localCarouselImages = existsSync(carouselDirUrl)
  ? readdirSync(carouselDirUrl, { withFileTypes: true })
      .filter((entry) => entry.isFile() && supportedExtensions.has(extname(entry.name).toLowerCase()))
      .map((entry) => entry.name)
      .sort((a, b) => a.localeCompare(b, 'pt', { numeric: true, sensitivity: 'base' }))
      .map((fileName) => ({
        src: `${basePath}images/carrossel/${encodeURIComponent(fileName)}`,
        alt: makeAltFromFileName(fileName)
      }))
  : [];

const carouselImages = localCarouselImages.length > 0 ? localCarouselImages : fallbackCarouselImages;
---

<BaseLayout title="Página única · Isabelinha e João" description="Versão em página única para comparação.">
  <div id="topo" class="onepage-section">
    <Hero names={site.names} date={site.date} location={site.location} />
  </div>

  <section class="section section-home-carousel onepage-section" aria-label="Galeria de imagens">
    <div class="container">
      <ImageCarousel images={carouselImages} />
    </div>
  </section>

  <section class="section section-home-about onepage-section" id="sobre-nos" aria-labelledby="sobre-nos-title">
    <div class="container">
      <div class="home-about">
        <h2 class="section-title" id="sobre-nos-title">Sobre nós</h2>
        <p class="about-text">{about}</p>
      </div>
    </div>
  </section>

  <section class="section section-page-head onepage-section" id="dia-18" aria-labelledby="dia-18-title">
    <div class="container">
      <header class="page-head">
        <h2 class="section-title" id="dia-18-title">O dia 18</h2>
      </header>

      <div class="timeline" aria-label="Timeline do dia 18">
        {
          events.map((event, index) => (
            <div class="timeline-item">
              <span class="timeline-point" aria-hidden="true">{index + 1}</span>
              <EventCard event={event} />
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section section-page-head onepage-section" id="presente" aria-labelledby="presente-title">
    <div class="container">
      <header class="page-head">
        <h2 class="section-title" id="presente-title">Presente</h2>
      </header>

      <div class="gifts-shell">
        <p class="section-intro" style="margin-top: 0.8rem;">{introducao}</p>
        <p class="section-intro" style="margin-top: 0.8rem;">{introducao2}</p>

        <section class="payment" aria-label="Detalhes de pagamento">
          <div class="payment-grid">
            {detalhesPagamento.map((pessoa) => (
              <article class="payment-card">
                <h3 class="payment-name">{pessoa.nome}</h3>

                <dl class="payment-dl">
                  <div class="payment-row">
                    <dt class="payment-label">
                      <span>IBAN</span>
                      <button
                        type="button"
                        class="payment-copy"
                        data-copy={pessoa.iban}
                        aria-label={`Copiar IBAN de ${pessoa.nome}`}
                      >
                        Copiar
                      </button>
                    </dt>
                    <dd class="payment-mono payment-wrap">{pessoa.iban}</dd>
                  </div>
                </dl>
              </article>
            ))}
          </div>
        </section>

        <div class="gift-grid" aria-live="polite">
          {
            itens.map((item) => (
              <GiftCard
                title={item.nome}
                imageSrc={item.imagem}
                imageAlt={`Imagem ilustrativa: ${item.nome}`}
              />
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="section section-page-head onepage-section" id="como-voltar" aria-labelledby="como-voltar-title">
    <div class="container">
      <header class="page-head">
        <h2 class="section-title" id="como-voltar-title">Como voltar</h2>
        <p class="section-intro" style="margin-top: 0.8rem;">Para terminar o dia sem preocupações.</p>
      </header>

      <div class="return-shell">
        <p class="section-intro">
          Para quem quiser ir para casa descansado depois do casamento, sugerimos marcar um driver com antecedência.
          Assim não têm de se preocupar com nada no próprio dia.
        </p>

        <article class="payment-card return-card">
          <h3 class="payment-name">Contacto</h3>
          <p class="return-name">Manuel Maio</p>
          <a class="btn btn-secondary return-phone" href="tel:+351911110911">+351 911 110 911</a>
        </article>
      </div>
    </div>
  </section>

  <script is:inline>
    (function () {
      function fallbackCopy(text) {
        const ta = document.createElement('textarea');
        ta.value = text;
        ta.setAttribute('readonly', '');
        ta.style.position = 'fixed';
        ta.style.top = '-9999px';
        document.body.appendChild(ta);
        ta.select();
        try { document.execCommand('copy'); } catch (e) {}
        document.body.removeChild(ta);
      }

      async function copyText(text) {
        try {
          if (navigator.clipboard && window.isSecureContext) {
            await navigator.clipboard.writeText(text);
          } else {
            fallbackCopy(text);
          }
        } catch (e) {
          fallbackCopy(text);
        }
      }

      function flash(btn) {
        const prev = btn.textContent;
        btn.textContent = 'Copiado';
        btn.disabled = true;
        window.setTimeout(() => {
          btn.textContent = prev;
          btn.disabled = false;
        }, 900);
      }

      document.addEventListener('click', async (e) => {
        const btn = e.target && e.target.closest && e.target.closest('button[data-copy]');
        if (!btn) return;
        const text = btn.getAttribute('data-copy') || '';
        if (!text) return;
        await copyText(text);
        flash(btn);
      });
    })();
  </script>

  <style>
    .onepage-section {
      scroll-margin-top: 5.2rem;
    }

    .payment-grid { max-width: 720px; }

    .payment-row {
      display: flex;
      flex-direction: column;
      gap: 0.35rem;
    }

    .payment-row dt {
      font-size: 0.85rem;
      opacity: 0.65;
      font-weight: 500;
    }

    .payment-label {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.75rem;
    }

    .payment-wrap {
      white-space: nowrap;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      min-width: 0;
    }

    .payment-copy {
      border: 1px solid rgba(0, 0, 0, 0.12);
      background: rgba(255, 255, 255, 0.6);
      border-radius: 10px;
      padding: 0.35rem 0.6rem;
      font-size: 0.9rem;
      cursor: pointer;
      white-space: nowrap;
    }

    .payment-copy:disabled {
      cursor: default;
      opacity: 0.7;
    }

    .return-shell {
      margin-top: 0.95rem;
      display: grid;
      gap: 1rem;
      max-width: 44rem;
    }

    .return-card {
      width: min(100%, 26rem);
    }

    .return-name {
      margin-top: 0.35rem;
      color: var(--muted);
      font-weight: 500;
    }

    .return-phone {
      margin-top: 0.95rem;
      width: fit-content;
      text-decoration: none;
    }

    @media (max-width: 520px) {
      .return-card {
        width: 100%;
      }

      .return-phone {
        width: 100%;
      }
    }
  </style>
</BaseLayout>
